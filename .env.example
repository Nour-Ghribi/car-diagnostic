# OpenAI API key used only when an OpenAI provider is enabled.
OPENAI_API_KEY=

# Embedding provider for intent retrieval: mock | sbert | openai
INTENT_EMBEDDING_PROVIDER=sbert

# Reranker provider for candidate selection: mock | openai
INTENT_RERANKER_PROVIDER=mock

# Local SentenceTransformers model used when INTENT_EMBEDDING_PROVIDER=sbert
SBERT_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# OpenAI embedding model used when INTENT_EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI reranker model used when INTENT_RERANKER_PROVIDER=openai
OPENAI_RERANKER_MODEL=gpt-5.1

# Optional retrieval top-k used by the V3 intent parser
INTENT_RETRIEVAL_TOP_K=6

# Accept broad automotive health prompts above this threshold
INTENT_BROAD_ACCEPT_THRESHOLD=0.50

# Trigger LLM fallback only below this threshold
INTENT_LLM_FALLBACK_THRESHOLD=0.46

# Enable extra debug-oriented behavior or logging hooks
AGENT_DEBUG=false
